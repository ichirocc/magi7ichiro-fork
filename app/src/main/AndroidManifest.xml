<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- 最適化完了通知（Android 13+ は実行時許可が必要） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- バックグラウンド最適化を前景サービスとして実行（5分のCPUジョブをOSに止められない） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <application
        android:theme="@style/Theme.Magi"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:supportsRtl="true">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- [クラッシュ修正/実機報告「閉じても大丈夫でクラッシュ」] targetSdk 34+ では、Worker の
             setForeground(FOREGROUND_SERVICE_TYPE_DATA_SYNC) に対応する型を WorkManager の前景サービス
             宣言側にもマージで明記しないと、起動の瞬間に MissingForegroundServiceTypeException で落ちる
             （権限 FOREGROUND_SERVICE_DATA_SYNC だけでは不足。例外はサービス側スレッドで発生するため
             コード側の runCatching では捕捉不能）。 -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />
    </application>
</manifest>
